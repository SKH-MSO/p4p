# ─────────────────────────────────────────────────────────────
# Required by the deployed app (main.js) — set these in Vercel
# ─────────────────────────────────────────────────────────────

# LINE Messaging API
LINE_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Telegram approve/reject buttons on new access requests (optional feature —
# see scripts/telegram-approve-buttons.sql). Leave unset to disable the
# /telegram/webhook handler's effects.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Bypasses RLS — used by the /telegram/webhook handler and by
# /admin/api/line-bindings to act on service_role-only tables on the admin's
# behalf.
SUPABASE_SERVICE_ROLE_KEY=

# Shared password gating /admin/* (HTTP Basic Auth — any username works, only
# the password is checked). Leave unset to disable /admin entirely (returns 503).
ADMIN_PASSWORD=

# Local dev only — Vercel provides PORT automatically
# PORT=3000

# ─────────────────────────────────────────────────────────────
# Only for the admin scripts in scripts/ (NOT needed by the app)
# ─────────────────────────────────────────────────────────────
# LINE_TOKEN=        # setup-richmenu.mjs, update-month-picker.mjs
# LINE_USER_ID=      # send-test-flex.mjs
