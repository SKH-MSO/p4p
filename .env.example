# ── Required ──────────────────────────────────────────────────────────────────
# Google OAuth2 credentials (run `npm run setup` to generate GOOGLE_REFRESH_TOKEN)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Anthropic Claude API key
ANTHROPIC_API_KEY=
# Override Anthropic base URL (e.g. for DeepSeek compatibility)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Supabase project credentials
SUPABASE_URL=
SUPABASE_KEY=

# Telegram Bot API (from @BotFather) and target chat/group/channel ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional ──────────────────────────────────────────────────────────────────
# Google Drive folder ID for P4P uploads (Drive upload disabled if absent)
P4P_FOLDER_ID=

# Override default Claude model (default: claude-sonnet-4-5)
# CLAUDE_MODEL=claude-sonnet-4-5

# Maximum Gmail messages to fetch per run (default: 10)
# MAX_MESSAGES=10

# Minimum name-match similarity threshold 0–1 (default: 0.6)
# SIMILARITY_THRESHOLD=0.6

# Comma-separated sender emails to skip entirely
# SKIP_SENDERS=sakhonmso@gmail.com,p4pskh@gmail.com

# Set to any value to enable debug logging
# DEBUG=1
